# Incident Investigation Kit - Environment Variables
# Copy this file to .env and fill in your values
# Or run ./setup.sh for interactive setup

# Setup Status
SETUP_COMPLETE=true

# ============================================================================
# REQUIRED: Dynatrace
# ============================================================================
# How to generate a token:
#   1. Log in to the Dynatrace portal
#   2. Click your name (bottom-left) → Account Management
#      See: docs/account-management-button-dynatrace.png
#   3. Navigate to My Platform Tokens → Create token
#      See: docs/platform-tokens-section-dynatrace.png
#   4. Grant these scopes:
#        storage:logs:read
#        storage:events:read
#        storage:metrics:read
#        storage:entities:read
#        storage:spans:read
#        storage:buckets:read
DYNATRACE_TOKEN=YOUR_TOKEN_HERE
DYNATRACE_ENVIRONMENT=https://kroger-prod.apps.dynatrace.com/

# ============================================================================
# OPTIONAL: Jira / Atlassian API Configuration
# ============================================================================
# Uncomment if you want to search Jira during investigations
# Generate token at: https://id.atlassian.com/manage-profile/security/api-tokens

# ATLASSIAN_EMAIL=your.email@kroger.com
# ATLASSIAN_TOKEN=your-token-here
# ATLASSIAN_DOMAIN=kroger.atlassian.net

# ============================================================================
# AUTO-DETECTED: Repository Locations
# ============================================================================
CUE_REPO_PATH=../cue
ACL_REPO_PATH=../acl
CQS_REPO_PATH=../cqs
